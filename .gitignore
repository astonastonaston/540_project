# ──────────────────────────────────────────────────────────────────────────────
# .gitignore — Red-Teaming the Robot project
# ──────────────────────────────────────────────────────────────────────────────

# ── API Keys (NEVER commit real keys) ─────────────────────────────────────────
api_key.py

# ── Python cache ──────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
.Python
env/
venv/
.venv/
pip-log.txt

# ── Generated figures (auto-regenerated by experiment scripts) ────────────────
# Run `python run_multi_llm_experiment.py --figs-only` to regenerate
/figures/

# ── Experiment results (large JSON data + rendered images) ───────────────────
# Run experiment scripts to regenerate; renders can be GB-scale
/results/

# NOTE: report/figures/ is intentionally NOT ignored — those PNGs are committed
# because they are needed to compile report/main.tex on a fresh machine.

# ── LaTeX build artifacts ─────────────────────────────────────────────────────
*.aux
*.bbl
*.bcf
*.blg
*.fls
*.fdb_latexmk
*.log
*.nav
*.out
*.run.xml
*.snm
*.synctex.gz
*.toc
*.vrb
# But DO keep compiled PDFs (easy to verify the report compiled correctly):
!report/main.pdf
!slides/*.pdf

# ── Shell output logs ─────────────────────────────────────────────────────────
*.out
!report/main.pdf    # .out rule above would match — override it

# ── Archives ──────────────────────────────────────────────────────────────────
*.zip
*.tar.gz

# ── OS / editor junk ─────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

report
slides

